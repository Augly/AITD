from __future__ import annotations

import signal
import sys
import threading
from types import ModuleType
from typing import Any


class SecurityError(RuntimeError):
    """Raised when sandboxed code attempts an unsafe operation."""


# Built-ins that must never be exposed to sandboxed code.
_BANNED_BUILTINS: frozenset[str] = frozenset({
    "__import__",
    "eval",
    "exec",
    "compile",
    "open",
    "input",
    "raw_input",  # Python 2 compat (harmless on Py3)
    "reload",
    "help",
})

# Modules that may be imported by sandboxed code.
_DEFAULT_ALLOWED_MODULES: frozenset[str] = frozenset({
    "json",
    "math",
    "re",
    "datetime",
    "random",
    "statistics",
    " itertools",
    "collections",
    "typing",
    "decimal",
    "fractions",
    "hashlib",
    "string",
    "time",
})


def _build_safe_builtins() -> dict[str, Any]:
    """Return a copy of builtins with dangerous functions removed."""
    safe: dict[str, Any] = {}
    builtins_module = sys.modules["builtins"]
    for name in dir(builtins_module):
        if name.startswith("_") and name not in {"__name__", "__doc__", "__build_class__"}:
            continue
        if name in _BANNED_BUILTINS:
            continue
        safe[name] = getattr(builtins_module, name)
    return safe


SAFE_BUILTINS: dict[str, Any] = _build_safe_builtins()


def _make_restricted_import(allowed_modules: set[str]) -> Any:
    """Return an __import__ replacement that only allows whitelisted modules."""

    def restricted_import(
        name: str,
        globals: dict[str, Any] | None = None,  # noqa: A002
        locals: dict[str, Any] | None = None,  # noqa: A002
        fromlist: tuple[str, ...] = (),
        level: int = 0,
    ) -> ModuleType:
        # Resolve relative imports to absolute names for checking.
        if level > 0:
            # Relative imports are not supported in the sandbox.
            raise SecurityError(f"Relative imports are not allowed (attempted: {name!r}).")

        # Determine the top-level package name.
        top_level = name.split(".")[0]
        if top_level not in allowed_modules:
            raise SecurityError(
                f"Import of module {name!r} is not allowed. "
                f"Allowed modules: {sorted(allowed_modules)}"
            )

        # Perform the actual import.
        module = __import__(name, globals, locals, fromlist, level)

        # Wrap the module so that accessing __builtins__ returns safe builtins.
        return _wrap_module(module, allowed_modules)

    return restricted_import


def _wrap_module(module: ModuleType, allowed_modules: set[str]) -> ModuleType:
    """Wrap a module to prevent access to dangerous builtins via module.__builtins__."""
    # Only wrap modules that have not already been wrapped.
    if getattr(module, "__sandbox_wrapped__", False):
        return module

    wrapped = ModuleType(module.__name__)
    wrapped.__dict__.update(module.__dict__)
    wrapped.__sandbox_wrapped__ = True  # type: ignore[attr-defined]

    # Replace __builtins__ with safe version.
    wrapped.__builtins__ = SAFE_BUILTINS  # type: ignore[attr-defined]

    # Also wrap submodules that are already loaded.
    for attr_name in dir(module):
        try:
            attr = getattr(module, attr_name)
        except Exception:
            continue
        if isinstance(attr, ModuleType) and attr.__name__ != module.__name__:
            if attr.__name__.split(".")[0] in allowed_modules:
                wrapped_attr = _wrap_module(attr, allowed_modules)
                setattr(wrapped, attr_name, wrapped_attr)

    return wrapped


class _TimeoutExecutor:
    """Execute code with a timeout using a background thread."""

    def __init__(self, timeout_seconds: float) -> None:
        self.timeout_seconds = timeout_seconds
        self._result: Any = None
        self._exception: BaseException | None = None
        self._done = threading.Event()

    def _run(
        self,
        source_code: str,
        scope: dict[str, Any],
        allowed_modules: set[str],
    ) -> None:
        try:
            safe_scope = dict(scope)
            safe_scope["__builtins__"] = dict(SAFE_BUILTINS)
            safe_scope["__builtins__"]["__import__"] = _make_restricted_import(allowed_modules)

            exec(source_code, safe_scope)  # noqa: S102
            self._result = safe_scope
        except BaseException as exc:
            self._exception = exc
        finally:
            self._done.set()

    def execute(
        self,
        source_code: str,
        scope: dict[str, Any],
        allowed_modules: set[str],
    ) -> dict[str, Any]:
        thread = threading.Thread(
            target=self._run,
            args=(source_code, scope, allowed_modules),
            daemon=True,
        )
        thread.start()
        if not self._done.wait(timeout=self.timeout_seconds):
            raise TimeoutError(
                f"Sandboxed code exceeded {self.timeout_seconds}s timeout."
            )
        if self._exception is not None:
            raise self._exception
        return self._result


def run_restricted_python(
    source_code: str,
    scope: dict[str, Any] | None = None,
    allowed_modules: set[str] | None = None,
    timeout_seconds: float = 30.0,
) -> dict[str, Any]:
    """Execute Python source code in a restricted sandbox.

    Args:
        source_code: The Python source code to execute.
        scope: Initial variables to inject into the execution scope.
        allowed_modules: Set of module names that may be imported.
            Defaults to a safe whitelist (json, math, re, datetime, etc.).
        timeout_seconds: Maximum execution time before raising TimeoutError.

    Returns:
        The execution scope dictionary after the code runs.

    Raises:
        SecurityError: If the code attempts to use banned builtins or
            import disallowed modules.
        TimeoutError: If execution exceeds the timeout.
        SyntaxError: If the source code has invalid syntax.
    """
    scope = scope or {}
    allowed = set(allowed_modules) if allowed_modules is not None else set(_DEFAULT_ALLOWED_MODULES)

    executor = _TimeoutExecutor(timeout_seconds)
    return executor.execute(source_code, scope, allowed)

