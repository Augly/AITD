+            "low": num(row[3]),
+            "close": num(row[4]),
+            "volume": num(row[5]),
+        }
+        if quote_volume_index is not None and quote_volume_index < len(row):
+            candle["quoteVolume"] = num(row[quote_volume_index])
+        candles.append(candle)
+    if reverse:
+        candles.reverse()
+    return candles
