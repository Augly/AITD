   291	        now_ms = int(__import__("time").time() * 1000)
   292	        with self._exchange_info_lock:
   293	            if self._exchange_info_cache is not None and self._exchange_info_expires_at_ms > now_ms:
   294	                return self._exchange_info_cache
   295	            url = f"{self.resolved_base_url(config).rstrip('/')}/fapi/v1/exchangeInfo"
   296	            payload = cached_get_json(
   297	                url,
   298	                namespace="binance_live_exchange_info",
   299	                ttl_seconds=6 * 60 * 60,
   300	                max_stale_seconds=7 * 24 * 60 * 60,
   301	                timeout_seconds=45,
   302	                network_settings=self._get_network_settings(),
   303	            )
   304	            result = payload if isinstance(payload, dict) else {}
   305	            self._exchange_info_cache = result
   306	            self._exchange_info_expires_at_ms = now_ms + 6 * 60 * 60 * 1000
   307	            return result
