        network_settings_provider=network_settings_provider,
    )
    _GATEWAYS["bybit"] = BybitGateway(
        config_provider=config_provider,
        network_settings_provider=network_settings_provider,
    )
    _GATEWAYS["okx"] = OkxGateway(
        config_provider=config_provider,
        network_settings_provider=network_settings_provider,
    )


