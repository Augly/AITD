   224	    def _signed_params(self, config: dict[str, Any], params: dict[str, Any] | None = None) -> str:
   225	        payload = dict(params or {})
   226	        payload["timestamp"] = str(int(__import__("time").time() * 1000) + int(self._server_time_offset_ms or 0))
   227	        payload["recvWindow"] = str(int(config.get("recvWindow") or 5000))
   228	        query_string = urlencode({key: value for key, value in payload.items() if value not in (None, "")})
   229	        signature = hmac.new(
   230	            str(config["apiSecret"]).encode("utf-8"),
   231	            query_string.encode("utf-8"),
   232	            hashlib.sha256,
   233	        ).hexdigest()
   234	        return f"{query_string}&signature={signature}"
   235	
   236	    def _sync_server_time_offset(self, config: dict[str, Any]) -> None:
   237	        base_url = self.resolved_base_url(config).rstrip("/")
   238	        payload = request_json(
   239	            "GET",
   240	            f"{base_url}/fapi/v1/time",
   241	            timeout_seconds=10,
   242	            network_settings=self._get_network_settings(),
   243	        )
   244	        server_time = num(payload.get("serverTime")) if isinstance(payload, dict) else None
   245	        local_time = int(__import__("time").time() * 1000)
   246	        if server_time is not None:
   247	            self._server_time_offset_ms = int(server_time) - local_time
   248	
   249	    def _signed_request_json(
   250	        self,
   251	        config: dict[str, Any],
   252	        method: str,
   253	        endpoint: str,
   254	        params: dict[str, Any] | None = None,
   255	    ) -> Any:
   256	        base_url = self.resolved_base_url(config).rstrip("/")
   257	        headers_base = {"X-MBX-APIKEY": config["apiKey"]}
   258	
   259	        def send_once() -> Any:
   260	            query = self._signed_params(config, params)
   261	            url = f"{base_url}{endpoint}"
   262	            if method.upper() in {"GET", "DELETE"}:
   263	                return request_json(
   264	                    method,
   265	                    f"{url}?{query}",
   266	                    headers=headers_base,
   267	                    timeout_seconds=45,
   268	                    network_settings=self._get_network_settings(),
   269	                )
   270	            return request_json(
   271	                method,
   272	                url,
   273	                headers={
   274	                    **headers_base,
   275	                    "content-type": "application/x-www-form-urlencoded",
   276	                },
   277	                payload=query,
   278	                timeout_seconds=45,
   279	                network_settings=self._get_network_settings(),
   280	            )
   281	
   282	        try:
   283	            return send_once()
   284	        except HttpRequestError as error:
   285	            if "-1021" in str(error):
   286	                self._sync_server_time_offset(config)
   287	                return send_once()
   288	            raise HttpRequestError(f"{error} [endpoint {method.upper()} {endpoint}]") from error
